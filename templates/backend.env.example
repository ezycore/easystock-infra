# ── easystock-backend runtime env ──────────────────────────────────────────────
# Copy to the server as BOTH:
#   /opt/easystock/production/.env.backend   (prod values)
#   /opt/easystock/staging/.env.backend      (staging values)
# Fill every blank. Never commit the filled-in file (it's gitignored).

NODE_ENV=production
PORT=5000                     # MUST be 5000 — Caddy proxies api.* → backend-prod:5000

# MongoDB Atlas — PROD cluster for production, STAGING cluster for staging. DB name = easystock.
MONGODB_URI=mongodb+srv://easystock_app:PASSWORD@cluster0.xxxxx.mongodb.net/easystock?retryWrites=true&w=majority

# Auth — generate a unique value per environment:  openssl rand -hex 48
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Point CORS + links at THIS env's frontend:
#   production →  https://app.ezycore.com
#   staging    →  https://rc.ezycore.com
CORS_ORIGIN=https://rc.ezycore.com
FRONTEND_URL=https://rc.ezycore.com
# Apex domain so CORS accepts every workspace subdomain (acme.ezycore.com) plus
# the apex/www. Same value in staging & production.
ROOT_DOMAIN=ezycore.com

# Shared secret for the custom-domain on-demand-TLS `ask` endpoint. MUST match
# DOMAIN_CHECK_SECRET in /opt/easystock/infra/.env (the Caddy container). Custom
# domains are production only. Generate: openssl rand -hex 32. See CUSTOM-DOMAINS-P1.md.
DOMAIN_CHECK_SECRET=

# Cloudflare R2 (image storage) — your real bucket creds
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL of the bucket (custom domain or r2.dev), no trailing slash
R2_PUBLIC_URL=
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Email (SMTP / Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EasyStock <no-reply@ezycore.com>"

# Email — DigitalOcean blocks outbound SMTP, so use Resend's HTTP API (port 443).
EMAIL_PROVIDER=resend
# Per-environment Resend account key (separate accounts so staging/prod quotas
# don't collide). Lives only on the server.
RESEND_API_KEY=
# Sender on a Resend-verified domain — per environment:
#   production →  EasyStock <noreply@ezycore.com>
#   staging    →  EasyStock <noreply@rc.ezycore.com>
EMAIL_FROM="EasyStock <noreply@rc.ezycore.com>"

# Telegram ops alerts — one bot per environment (staging bot vs prod bot).
TELEGRAM_ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

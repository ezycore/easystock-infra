# ── easystock-frontend runtime env ─────────────────────────────────────────────
# The customer API URL (NEXT_PUBLIC_API_URL) is baked into the image AT BUILD TIME
# (§10.1), so the running container needs essentially nothing here — NODE_ENV is
# already set in the image. This file exists only because docker-compose references
# `env_file: ./.env.frontend`. Copy it to /opt/easystock/{production,staging}/.env.frontend.
NODE_ENV=production

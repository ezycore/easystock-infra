# ── infra (Caddy reverse proxy) runtime env ─────────────────────────────────
# Copy to /opt/easystock/infra/.env on the server (gitignored). Docker Compose
# auto-loads this file for ${VAR} substitution in infra/docker-compose.yml.

# Cloudflare API token used by Caddy's DNS-01 challenge to issue the
# *.ezycore.com wildcard cert (DEPLOYMENT.md §17.3). Create a SCOPED token:
#   Cloudflare dashboard → My Profile → API Tokens → Create Token
#   Permissions: Zone → DNS → Edit, restricted to the ezycore.com zone.
# Required only for the wildcard; the apex and other hosts use HTTP-01.
CLOUDFLARE_API_TOKEN=

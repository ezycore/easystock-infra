# ── mission-control-admin runtime env ──────────────────────────────────────────
# Like the frontend, the admin's API URL (NEXT_PUBLIC_API_URL) is baked at BUILD TIME
# (§8.4), so the running container reads nothing at runtime. This file exists only for
# compose's `env_file: ./.env.mc-admin`. Copy to /opt/easystock/{production,staging}/.env.mc-admin.
NODE_ENV=production

# ── mission-control (MC API) runtime env ───────────────────────────────────────
# Copy to /opt/easystock/{production,staging}/.env.mc-api on the server.
# The app REFUSES to boot without: MONGODB_URI, JWT_ACCESS_SECRET,
# JWT_REFRESH_SECRET, ENCRYPTION_KEY. Everything else has a safe default.

NODE_ENV=production
PORT=6000                     # MUST be 6000 — Caddy proxies mc-api.* → mc-api-prod:6000

# MC's OWN database ("mc") on THIS env's Atlas cluster (separate from the product DB).
MONGODB_URI=mongodb+srv://easystock_app:PASSWORD@cluster0.xxxxx.mongodb.net/mc?retryWrites=true&w=majority

# Auth — generate unique per env:  openssl rand -hex 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AES-256-GCM master key — exactly 64 hex chars. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# URLs — point at THIS env:
#   production →  admin https://mc.ezycore.com     api https://mc-api.ezycore.com
#   staging    →  admin https://rc-mc.ezycore.com  api https://rc-mc-api.ezycore.com
CORS_ORIGIN=https://rc-mc.ezycore.com
ADMIN_BASE_URL=https://rc-mc.ezycore.com
PUBLIC_BASE_URL=https://rc-mc-api.ezycore.com

# Cloudflare Pages Deploy Hook for the marketing site (ezycore.com). MC POSTs here
# when a PUBLIC plan changes so pricing auto-rebuilds. Create it in: Cloudflare Pages
# → project → Settings → Builds & deployments → Deploy hooks. Empty = disabled.
MARKETING_DEPLOY_HOOK_URL=

# Cron — TRUE in production so dunning / trial-expiry / webhook-retry actually run.
CRON_ENABLED=true

# Email (admin alerts + customer notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mission Control <no-reply@ezycore.com>"

# DigitalOcean blocks outbound SMTP, so use Resend's HTTP API (port 443).
EMAIL_PROVIDER=resend
# Per-environment Resend account key (separate accounts so staging/prod quotas
# don't collide). Lives only on the server.
RESEND_API_KEY=
# Sender on a Resend-verified domain — per environment:
#   production →  Mission Control <mc@ezycore.com>
#   staging    →  Mission Control <mc@rc.ezycore.com>
EMAIL_FROM="Mission Control <mc@rc.ezycore.com>"

# Telegram ops alerts — one bot per environment (staging bot vs prod bot).
TELEGRAM_ALERTS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MC_ALERT_EMAIL=you@ezycore.com

# Billing tuning (defaults are fine to start)
DEFAULT_CURRENCY=usd
DUNNING_GRACE_DAYS=3
ENTITLEMENT_STALE_HOURS=24
SEND_INVOICE_DAYS_UNTIL_DUE=7

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100000

# First owner account (used ONLY by `pnpm seed:admin`, run once)
SEED_ADMIN_EMAIL=owner@ezycore.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FIRST_NAME=Mission
SEED_ADMIN_LAST_NAME=Owner

# NOTE: Stripe / SSLCommerz credentials are NOT env vars — they're created inside MC Admin
# and stored AES-encrypted in the DB (see §12). Nothing to add here for gateways.

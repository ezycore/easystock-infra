# Caddy reverse proxy — HTTPS front door for the whole EasyStock stack.
# One Caddy instance serves the apex, every staging/production host, and the
# *.ezycore.com workspace wildcard. Upstreams are app *container names* on the
# shared `edge` Docker network (see infra/docker-compose.yml + §10).
#
# Most certs come from Let's Encrypt automatically (HTTP-01). The *.ezycore.com
# wildcard uses a DNS-01 challenge via the Cloudflare plugin (needs a custom
# Caddy image + CLOUDFLARE_API_TOKEN — see Dockerfile + docker-compose.yml).
# Concrete-host certs are obtained at startup; until the app containers exist
# each returns HTTPS 502 — expected. Verify: curl -I https://rc-mc-api.ezycore.com

{
    email rashidul.karim7@gmail.com    # ACME account email (Let's Encrypt expiry notices). Change if you like.

    # On-demand TLS for customer CUSTOM DOMAINS. Before issuing a cert for an
    # unknown host, Caddy asks the backend whether that host is a verified/active
    # custom domain — prevents strangers pointing DNS at us to force cert issuance
    # (abuse / Let's-Encrypt rate limits). Secret-gated (DOMAIN_CHECK_SECRET must
    # be set on THIS caddy container; Caddy appends &domain=). Custom domains are
    # PRODUCTION only. See CUSTOM-DOMAINS-P1.md.
    on_demand_tls {
        ask http://backend-prod:5000/api/internal/domain-check?key={env.DOMAIN_CHECK_SECRET}
    }
}

# ---------- PRODUCTION ----------
app.ezycore.com {
    reverse_proxy frontend-prod:3000
}
api.ezycore.com {
    reverse_proxy backend-prod:5000
}
mc.ezycore.com {
    reverse_proxy mc-admin-prod:4000
}
mc-api.ezycore.com {
    reverse_proxy mc-api-prod:6000
}

# Portainer — admin-only ops UI. NOT public: Basic Auth over HTTPS (no IP allowlist,
# since admin has no fixed IP). Auth is the only gate — use a STRONG password.
# Generate the hash with:
#   docker run --rm caddy caddy hash-password --plaintext 'your-strong-pass'
# (Caddy < 2.8 uses `basicauth` instead of `basic_auth`.)
portainer.ezycore.com {
    basic_auth {
        admin $2a$14$goPzdzRpa8.sm5HMD4jKnu9.pwIiyTZpQz.tt1E6jMYJXdv8aN15q       # ← output of caddy hash-password
    }
    reverse_proxy portainer:9000
}

# Every workspace subdomain (acme.ezycore.com, …) → the customer frontend.
# Explicit hosts above always win over this wildcard. Cert via Cloudflare DNS-01
# (needs CLOUDFLARE_API_TOKEN; see Dockerfile + docker-compose.yml).
*.ezycore.com {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }
    reverse_proxy frontend-prod:3000
}

# ---------- STAGING ----------
rc.ezycore.com {
    reverse_proxy frontend-staging:3000
}
rc-api.ezycore.com {
    reverse_proxy backend-staging:5000
}
rc-mc.ezycore.com {
    reverse_proxy mc-admin-staging:4000
}
rc-mc-api.ezycore.com {
    reverse_proxy mc-api-staging:6000
}

# DNS records required for the blocks above (most-specific wins over the wildcard):
#   @ (apex) → server IP      www → server IP      * (wildcard) → server IP
# Apex/www certs use HTTP-01; the wildcard uses Cloudflare DNS-01 (token required).

# ---------- CUSTOM DOMAINS (production only) ----------
# Catch-all for customer custom domains (shop.acme.com, acme.com). Any host NOT
# matched by an explicit/​wildcard block above falls here: Caddy issues a per-host
# cert on demand via HTTP-01, gated by the global `on_demand_tls { ask ... }`
# block (only verified/active domains get a cert). Serves the PRODUCTION frontend.
#
# Staging custom domains are NOT supported: one catch-all → one upstream. A
# customer publishes either  CNAME → connect.ezycore.com  (subdomain) or
# A → <server IP>  (apex), plus the _ezycore-verify TXT record. Explicit hosts
# and *.ezycore.com always win over this block. See CUSTOM-DOMAINS-P1.md.
https:// {
    tls {
        on_demand
    }
    reverse_proxy frontend-prod:3000
}
